@headitem Key
@tab Command
@item @samp{RET}
@tab @code{infovore-list-show-item}
@item @samp{b}
@tab @code{infovore-list-browse-url}
@item @samp{r}
@tab @code{infovore-list-toggle-read}
@item @samp{s}
@tab @code{infovore-list-toggle-starred}
@item @samp{g}
@tab @code{infovore-list-refresh}
@item @samp{G}
@tab @code{infovore-fetch-now}
@item @samp{q}
@tab @code{quit-window}
@item @samp{S}
@tab @code{infovore-ebib-save}
@item @samp{+}
@tab @code{infovore-list-show-all}
@item @samp{-}
@tab @code{infovore-list-show-curated}
